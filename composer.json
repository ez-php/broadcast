{
  "name": "ez-php/broadcast",
  "version": "1.0.0",
  "description": "Real-time event broadcasting for ez-php — pluggable drivers (Null, Log, Array), SSE response helpers, and a static Broadcast facade",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["broadcast", "sse", "server-sent-events", "php", "framework", "ez-php"],
  "homepage": "https://github.com/ez-php/broadcast",
  "support": {
    "issues": "https://github.com/ez-php/broadcast/issues",
    "source": "https://github.com/ez-php/broadcast"
  },
  "require": {
    "php": "^8.5",
    "ez-php/contracts": "^1.0"
  },
  "require-dev": {
    "ez-php/docker": "^1.0",
    "ez-php/testing-application": "^1.0",
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Broadcast\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
